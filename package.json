{
  "name": "glint",
  "version": "0.0.1",
  "description": "Unified WebGPU/WebGL2 renderer with one API, one shader language.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./2d": {
      "types": "./dist/2d/index.d.ts",
      "import": "./dist/2d/index.js"
    },
    "./3d": {
      "types": "./dist/3d/index.d.ts",
      "import": "./dist/3d/index.js"
    },
    "./viz": {
      "types": "./dist/viz/index.d.ts",
      "import": "./dist/viz/index.js"
    },
    "./anim": {
      "types": "./dist/anim/index.d.ts",
      "import": "./dist/anim/index.js"
    },
    "./post": {
      "types": "./dist/post/index.d.ts",
      "import": "./dist/post/index.js"
    },
    "./xr": {
      "types": "./dist/xr/index.d.ts",
      "import": "./dist/xr/index.js"
    },
    "./physics": {
      "types": "./dist/physics/index.d.ts",
      "import": "./dist/physics/index.js"
    },
    "./audio": {
      "types": "./dist/audio/index.d.ts",
      "import": "./dist/audio/index.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js"
    },
    "./shader": {
      "types": "./dist/shader/index.d.ts",
      "import": "./dist/shader/index.js"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "import": "./dist/backend/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "size": "node scripts/bundle-size.mjs",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.44",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
